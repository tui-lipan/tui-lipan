  "Component boilerplate": {
    "prefix": "tui-component",
    "body": [
      "#[derive(Default)]",
      "pub struct ${1:MyComponent};",
      "",
      "pub enum ${2:Msg} {",
      "\t$3",
      "}",
      "",
      "#[derive(Default)]",
      "pub struct ${4:State} {",
      "\t$5",
      "}",
      "",
      "impl Component for ${1:MyComponent} {",
      "\ttype Message = ${2:Msg};",
      "\ttype Properties = ();",
      "\ttype State = ${4:State};",
      "",
      "\tfn create_state(&self, _props: &Self::Properties) -> Self::State {",
      "\t\t${4:State}::default()",
      "\t}",
      "",
      "\tfn update(&mut self, msg: ${2:Msg}, ctx: &mut Context<Self>) -> Update {",
      "\t\tmatch msg {",
      "\t\t\t$6",
      "\t\t}",
      "\t\tUpdate::full()",
      "\t}",
      "",
      "\tfn view(&self, ctx: &Context<Self>) -> Element {",
      "\t\tui! {",
      "\t\t\t$0",
      "\t\t}",
      "\t}",
      "}"
    ],
    "description": "Full Component boilerplate with ui! macro"
