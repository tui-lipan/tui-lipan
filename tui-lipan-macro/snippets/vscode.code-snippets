  "ui! macro": {
    "prefix": "ui!",
    "body": [
      "ui! {",
      "\t${1:VStack::new()}${2: => {",
      "\t\t$0",
      "\t\\}}",
      "}"
    ],
    "description": "Autocomplete-friendly ui! macro with builder chains"
  },
