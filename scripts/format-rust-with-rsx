#!/usr/bin/env bash

set -euo pipefail

check=0
stdin_mode=0
files=()

for arg in "$@"; do
    case "$arg" in
        --check)
            check=1
            ;;
        --stdin)
            stdin_mode=1
            ;;
        -h|--help)
            cat <<'EOF'
Usage: scripts/format-rust-with-rsx [--check] [files...]
       scripts/format-rust-with-rsx --stdin

Formats Rust files with `cargo rsx-fmt` first, then `rustfmt`.
When no files are provided, all project Rust files are formatted.
EOF
            exit 0
            ;;
        -*)
            printf 'format-rust-with-rsx: unknown flag `%s`\n' "$arg" >&2
            exit 1
            ;;
        *)
            files+=("$arg")
            ;;
    esac
done

if [[ "$stdin_mode" -eq 1 ]]; then
    if [[ "$#" -ne 1 ]]; then
        printf 'format-rust-with-rsx: `--stdin` cannot be combined with other args\n' >&2
        exit 1
    fi

    cargo rsx-fmt --stdin | rustfmt --emit stdout --edition 2024
    exit 0
fi

if [[ "${#files[@]}" -eq 0 ]]; then
    mapfile -t files < <(rg --files --hidden -g '*.rs' -g '!target/**' -g '!.git/**' -g '!.*/**')

    if [[ "${#files[@]}" -eq 0 ]]; then
        printf 'format-rust-with-rsx: no Rust files found in the current directory\n' >&2
        exit 1
    fi
fi

if [[ "$check" -eq 1 ]]; then
    cargo rsx-fmt --check "${files[@]}"
    rustfmt --check --edition 2024 "${files[@]}"
else
    cargo rsx-fmt "${files[@]}"
    rustfmt --edition 2024 "${files[@]}"
fi
